---
import ContactForm from '../components/ContactForm.tsx';
import XIcon from '../components/XIcon.astro';
import Page from '../layouts/Page.astro';
import { CONTACT_EMAIL, X_HANDLE, X_URL } from '../consts';
---

<Page title="Contact" description="Get in touch with Giovanni Benussi">
	<article class="prose dark:prose-invert max-w-none">
		<h1>Say hi 👋</h1>
		<p>
			I'd love to hear from you — whether it's a question or just to say hello. Drop me a
			note below and I'll write back.
		</p>
	</article>
	<div class="mt-8">
		<ContactForm client:idle />
	</div>
	<article class="prose dark:prose-invert max-w-none mt-8">
		<p>
			You can also email me directly at
			<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
			or find me on <XIcon class="inline size-[0.9em] align-baseline" />
			<a href={X_URL} target="_blank" rel="noopener">@{X_HANDLE}</a>.
		</p>
	</article>
</Page>
