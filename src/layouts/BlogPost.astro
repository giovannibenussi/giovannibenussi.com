---
import { Image } from 'astro:assets';
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

type Props = CollectionEntry<'blog'>['data'] & { readTime?: string; id?: string };

const { title, description, pubDate, updatedDate, heroImage, readTime, id } = Astro.props;

const relatedPosts = (await getCollection('blog'))
	.filter((post) => post.id !== id)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 2);
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="w-full max-w-3xl mx-auto px-4 py-4">
			<article>
				<div class="prose text-gray-900 dark:text-gray-200 text-base leading-[1.7] font-normal antialiased" style="font-family: var(--font-content);">
					<div class="mb-6 text-left">
						<div class="text-sm text-gray-500">
							<FormattedDate date={pubDate} />
						</div>
						<h1 class="mt-1 mb-2 text-[2em] font-semibold leading-[1.2]">{title}</h1>
						<div class="text-sm text-gray-500">
							Giovanni Benussi{readTime && <span> · {readTime}</span>}
						</div>
						{
							updatedDate && (
								<div class="text-sm italic text-gray-500">
									Last updated on <FormattedDate date={updatedDate} />
								</div>
							)
						}
					</div>
					{heroImage && (
						<div class="mb-8">
							<Image width={1020} height={510} src={heroImage} alt="" class="block w-full h-auto max-h-[510px] object-contain rounded-md" />
						</div>
					)}
					<slot />
				</div>
				<RelatedArticles posts={relatedPosts} />
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.prose :global(h2) {
		font-size: 1.5em;
		font-weight: 600;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.prose :global(h3) {
		font-size: 1.25em;
		font-weight: 600;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
	}
	.prose :global(p) {
		margin-top: 0;
		margin-bottom: 16px;
	}
	.prose :global(a) {
		text-decoration: underline;
	}
</style>
